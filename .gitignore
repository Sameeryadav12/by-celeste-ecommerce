# --- Dependencies ---
node_modules/
**/node_modules/

# --- Build outputs ---
dist/
build/
**/dist/
**/build/
*.tsbuildinfo

# --- Environment & secrets (never commit) ---
.env
.env.*
!.env.example
!**/.env.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production.local

# --- Reference / competitor assets (do not publish) ---
frontend/public/images/reference/
**/public/images/reference/
reference/

# --- Local / IDE asset dumps (e.g. Cursor workspace images) ---
assets/

# --- Logs & caches ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.turbo/
.parcel-cache/
.eslintcache
coverage/
*.pid
*.seed
*.pid.lock

# --- OS & editors ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# --- Deployment platform local ---
.vercel/
.netlify/

# --- Prisma local SQLite (if ever used) ---
*.db
*.db-journal

# --- Misc ---
*.local
