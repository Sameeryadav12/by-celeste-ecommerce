# --- Dependencies ---
node_modules/
**/node_modules/

# --- Build outputs ---
dist/
build/
**/dist/
**/build/
*.tsbuildinfo

# --- Environment & secrets (never commit) ---
.env
.env.*
!.env.example
!**/.env.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production.local

# --- Reference / competitor assets (do not publish) ---
frontend/public/images/reference/
**/public/images/reference/
reference/

# --- Local / IDE asset dumps (e.g. Cursor workspace images) ---
assets/

# --- Logs & caches ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.turbo/
.parcel-cache/
.eslintcache
coverage/
*.pid
*.seed
*.pid.lock

# --- OS & editors ---
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# --- Deployment platform local ---
.vercel/
.netlify/

# --- Prisma local SQLite (if ever used) ---
*.db
*.db-journal

# --- Misc ---
*.local

# --- Local uploads (product/event images on server disk) ---
backend/uploads/products/*
!backend/uploads/products/.gitkeep
backend/uploads/events/*
!backend/uploads/events/.gitkeep

# --- Exported CSV downloads (local only) ---
**/exports/*.csv
*.export.csv

# --- Design / wireframe assets (keep locally; not needed on GitHub) ---
Canva/
wireframes/
New Wireframes/
Sprint 4 Wireframes/
Website_Requirement_Description*.png
Freight Calculator Flowchart.png
Perplexity.txt

# --- Cursor debug logs ---
.cursor/
debug-*.log
