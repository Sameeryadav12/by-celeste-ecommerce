# Local dev: leave unset — Vite proxies /api → http://localhost:4000 (see vite.config.ts).
# Dev UI: http://localhost:5174
#
# This repo uses VITE_API_BASE_URL (not VITE_API_URL).
#
# Production build (Vercel): public API origin, no trailing slash:
# VITE_API_BASE_URL=https://your-api.example.com
#
# Example (replace with your deployed API URL):
# VITE_API_BASE_URL=https://your-service.up.railway.app
