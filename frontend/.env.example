# Local dev: leave unset — Vite proxies /api → http://localhost:4000 (see vite.config.ts).
# Dev UI: http://localhost:5174
#
# This repo uses VITE_API_BASE_URL (not VITE_API_URL).
#
# Production (Vercel): REQUIRED — public origin of your Render API, no trailing slash:
# VITE_API_BASE_URL=https://your-service.onrender.com
#
# Optional: point a local build at a remote API:
# VITE_API_BASE_URL=https://staging-api.example.com
