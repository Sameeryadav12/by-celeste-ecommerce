# Local dev: leave unset — Vite proxies /api → http://localhost:4000 (see vite.config.ts).
#
# Production (e.g. Vercel): REQUIRED — public URL of your Render (or other) API, no trailing slash:
# VITE_API_BASE_URL=https://by-celeste-api.onrender.com
#
# Optional local override if you run the SPA build against a remote API:
# VITE_API_BASE_URL=https://staging-api.example.com
