  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "postinstall": "prisma generate",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:render": "npx prisma migrate deploy && node dist/scripts/seedCatalog.js && node dist/scripts/seedEvents.js && node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev && prisma generate",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "seed:catalog": "tsx src/scripts/seedCatalog.ts",
    "seed:events": "tsx src/scripts/seedEvents.ts",
    "seed:catalog:prod": "node dist/scripts/seedCatalog.js",
    "seed:events:prod": "node dist/scripts/seedEvents.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
