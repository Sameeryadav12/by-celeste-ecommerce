NODE_ENV="development"
# Default in code is 4000; Vite dev proxy targets this port (see frontend/vite.config.ts).
PORT="4000"

# CORS + cookies for browser. Defaults to http://localhost:5174 in development if omitted.
# Production (Vercel + Render): set to your exact storefront origin, e.g. https://by-celeste.vercel.app
# (no trailing slash). Required for browser access from a different host than the API.
FRONTEND_ORIGIN="http://localhost:5174"

# Cross-site auth (Vercel app + Render API on different domains): often need
# AUTH_COOKIE_SECURE="true" and AUTH_COOKIE_SAMESITE="none" (browser requires Secure with SameSite=None).

# Native Postgres (default port 5432)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/by_celeste?schema=public"

# Docker Postgres from backend/ (see docker-compose.yml): docker compose up -d
# DATABASE_URL="postgresql://byceleste:byceleste@localhost:5433/by_celeste?schema=public"

# --- Supabase + Railway / Render (production) ---
# Do NOT use the direct db.*.supabase.co URL on Railway (IPv6 ENETUNREACH). Use pooler host only.
#
# DATABASE_URL (runtime — Transaction pooler, port 6543):
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
#
# DIRECT_URL (migrations only — Session pooler, port 5432 on same pooler host):
# postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
#
# Copy both from Supabase → Project Settings → Database → Connection pooling (URI).
# Railway: set DATABASE_URL + DIRECT_URL, then redeploy. Migrations use DIRECT_URL via prisma.config.ts.

# Auth (JWT + HTTP-only cookie). Code reads JWT_ACCESS_SECRET — not JWT_SECRET.
JWT_ACCESS_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET"
JWT_ACCESS_EXPIRES_IN="7d"

# Optional: encrypt stored TOTP secrets at rest (admin 2FA). Must be exactly 64 hex characters (32 bytes).
# Generate e.g. openssl rand -hex 32
# If omitted, a key is derived from JWT_ACCESS_SECRET (fine for local dev; use a dedicated key in production).
# TOTP_ENCRYPTION_KEY=""

AUTH_COOKIE_NAME="by_celeste_access"
AUTH_COOKIE_SECURE="false"
AUTH_COOKIE_SAMESITE="lax"
AUTH_COOKIE_DOMAIN=""
AUTH_COOKIE_MAX_AGE_DAYS="7"

# Optional one-time admin bootstrap (never used by public signup)
ADMIN_BOOTSTRAP_EMAIL="admin.byceleste@gmail.com"
ADMIN_BOOTSTRAP_PASSWORD="Admin123!"
ADMIN_BOOTSTRAP_FIRSTNAME="Admin"
ADMIN_BOOTSTRAP_LASTNAME="User"

# --- Square (hosted checkout + webhooks) — required for live checkout ---
# Without SQUARE_ACCESS_TOKEN + SQUARE_LOCATION_ID, checkout shows:
# "Online payment is not connected yet. Please contact By Celeste."
# Sandbox API: https://connect.squareupsandbox.com | Production: https://connect.squareup.com
SQUARE_ACCESS_TOKEN="REPLACE_WITH_SQUARE_ACCESS_TOKEN"
SQUARE_ENVIRONMENT="sandbox"
SQUARE_LOCATION_ID="REPLACE_WITH_SQUARE_LOCATION_ID"
SQUARE_API_VERSION="2025-10-16"

# Required for production webhook verification (Square Developer Dashboard → Webhooks)
SQUARE_WEBHOOK_SIGNATURE_KEY="REPLACE_WITH_SUBSCRIPTION_SIGNATURE_KEY"
# Example local tunnel: https://YOUR_SUBDOMAIN.ngrok-free.app/api/webhooks/square
SQUARE_WEBHOOK_NOTIFICATION_URL="https://YOUR_PUBLIC_TUNNEL/api/webhooks/square"

# Where Square redirects after successful payment (orderId is appended automatically)
CHECKOUT_SUCCESS_REDIRECT_URL="http://localhost:5174/checkout/success"

# --- Production admin portal login (handover) ---
# Run: npm run seed:jane-admin
# Admin portal sign-in only: admin.byceleste@gmail.com (see businessDetails.ts adminEmail).
# Public support contact: jane.byceleste@gmail.com (supportEmail in businessDetails.ts).
# ADMIN_PASSWORD="REPLACE_WITH_SECURE_INITIAL_PASSWORD"
# JANE_ADMIN_PASSWORD=  # legacy alias for ADMIN_PASSWORD

# --- Demo admin (local / client demos only) ---
# Run: npm run seed:demo-admin
# Creates or refreshes admin.byceleste@gmail.com with role ADMIN (demo password; do not use in production).
# DEMO_ADMIN_ENABLED="true"  # optional if you use npm run seed:demo-admin instead
# DEMO_ADMIN_EMAIL="admin.byceleste@gmail.com"
# DEMO_ADMIN_PASSWORD="Admin123!"

# --- Demo customer (npm run seed:demo-customer or seed:demo-admin) ---
# customer@byceleste.com / Customer123!
# DEMO_CUSTOMER_EMAIL="customer@byceleste.com"
# DEMO_CUSTOMER_PASSWORD="Customer123!"

# --- Demo wholesale (same script: npm run seed:demo-admin) ---
# wholesale@byceleste.com / Wholesale123! — role WHOLESALE, APPROVED
# DEMO_WHOLESALE_EMAIL="wholesale@byceleste.com"
# DEMO_WHOLESALE_PASSWORD="Wholesale123!"

# --- Render (Web Service) quick reference ---
# Root directory: backend
# Build: npm install && npm run build
# Start: npm start   (or npm run start:render for migrate + seed + server — demo only)
# Env: PORT (Render sets automatically), DATABASE_URL, JWT_ACCESS_SECRET, FRONTEND_ORIGIN,
#      AUTH_COOKIE_SECURE=true, AUTH_COOKIE_SAMESITE=none (cross-site cookie to Vercel)

# --- Render / hosted demo only (omit for real production) ---
# If true, start:render also ensures demo admin + wholesale users exist.
# SEED_DEMO_USERS="true"

# --- Brevo (Sendinblue) SMTP for transactional emails ---
# Use the SMTP relay credentials from https://app.brevo.com/settings/keys/smtp.
# Leave SMTP_USER / SMTP_PASS empty to disable email sending. Code falls back to
# console links for the password reset flow when SMTP is not configured.
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Sender identity shown in transactional emails.
MAIL_FROM_NAME="By Celeste"
MAIL_FROM_EMAIL="hello@byceleste.com.au"

# Where admin alerts (new wholesale application, new paid order, test email) are sent.
ADMIN_NOTIFICATION_EMAIL="admin.byceleste@gmail.com"

# Public storefront URL used to build links inside emails (reset password, admin order page, etc.).
# Production: https://www.byceleste.com.au
FRONTEND_PUBLIC_URL="http://localhost:5174"

# Optional: minutes a password reset token is valid for. Defaults to 60 minutes.
# PASSWORD_RESET_TOKEN_TTL_MIN="60"
# Optional: override the base URL used to build reset links if it differs from FRONTEND_PUBLIC_URL.
# PASSWORD_RESET_LINK_BASE="https://www.byceleste.com.au"

